# ==============================================
# SeatReservation Environment Variables
# ==============================================
# Copy this file to .env and fill in the values
# $ cp .env.example .env

# ==============================================
# SYSTEM
# ==============================================
# Docker user ID and group ID (for file permissions)
# Get your values with: echo $UID:$GID
UID=1000
GID=1000

# ==============================================
# APPLICATION
# ==============================================
# Application base URL (e.g., http://localhost, https://example.com)
APP_URL=http://localhost:8080

# ==============================================
# DATABASE (PostgreSQL)
# ==============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=seatReservation

# ==============================================
# EMAIL CONFIGURATION
# ==============================================
# SMTP server settings for sending emails
MAIL_HOST=your-mail-host         # e.g., smtp.gmail.com
MAIL_PORT=your-mail-port         # e.g., 465 for SSL
MAIL_USERNAME=your-mail-username # Your email username/address
MAIL_PASSWORD=your-mail-password # Your email password or app password
MAIL_FROM=your-mail-from-address # The "from" address for sent emails
MAIL_TLS=false                   # Set to true if your SMTP server requires TLS
MAIL_START_TLS=REQUIRED          # Set to REQUIRED if your SMTP server requires STARTTLS

# Optional BCC address for all outgoing emails
EMAIL_BCC_ADDRESS=

# ==============================================
# SECURITY: CrowdSec Collaborative IPS
# ==============================================
# Bouncer API Key for CrowdSec integration (auto-blocking malicious IPs)
# REQUIRED for production: Generate with:
#   docker exec -it crowdsec cscli bouncers add nginx-bouncer
# Then copy the API Key here
CROWDSEC_BOUNCER_API_KEY=change_me_with_real_bouncer_key

# Log level for CrowdSec bouncer (trace, debug, info, warn, error)
# Default: info
CROWDSEC_LOG_LEVEL=info

